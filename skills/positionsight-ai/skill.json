{
  "name": "PositionSight AI",
  "slug": "positionsight-ai",
  "version": "1.0.0",
  "track": "Crypto Intelligence / Strategy Skills",
  "description": "Deterministic CMC-powered strategy skill that converts market data and user position inputs into a risk-aware, backtestable crypto strategy specification.",
  "backtestable": true,
  "liveTrading": false,
  "walletRequired": false,
  "onChainAgentAddressRequired": false,
  "onChainAgentAddress": "N/A",
  "inputSchema": {
    "type": "object",
    "required": [
      "symbol",
      "entryPrice",
      "totalCapital",
      "positionSize",
      "strategyTimeframe",
      "maxRiskPercentage",
      "strategyMode",
      "positionIntent"
    ],
    "properties": {
      "symbol": {
        "type": "string",
        "description": "Eligible crypto asset symbol."
      },
      "entryPrice": {
        "type": "number",
        "exclusiveMinimum": 0,
        "description": "Planned entry price or existing long-position average/original entry."
      },
      "totalCapital": {
        "type": "number",
        "exclusiveMinimum": 0,
        "description": "Capital base used for risk sizing."
      },
      "positionSize": {
        "type": "number",
        "exclusiveMinimum": 0,
        "description": "Token quantity for the planned or existing position."
      },
      "strategyTimeframe": {
        "type": "string",
        "enum": ["15m", "30m", "1h", "1d", "1w", "1mo"]
      },
      "maxRiskPercentage": {
        "type": "number",
        "minimum": 0.5,
        "maximum": 6
      },
      "strategyMode": {
        "type": "string",
        "enum": ["auto", "trend_confirmation", "breakout_retest", "defensive_rebound", "risk_check"]
      },
      "positionIntent": {
        "type": "string",
        "enum": ["analyze_entry", "manage_open_position", "exit_review"]
      }
    }
  },
  "outputSchema": {
    "type": "object",
    "required": [
      "schemaVersion",
      "skill",
      "dataProvenance",
      "strategySpec",
      "strategyDecision",
      "marketContext",
      "history",
      "backtestSpec",
      "validation"
    ],
    "properties": {
      "schemaVersion": {
        "type": "string"
      },
      "strategyDecision": {
        "type": "object",
        "required": ["positionIntent", "intentAction", "riskBadge", "stopStatus", "finalRiskVerdict"]
      },
      "riskBadge": {
        "type": "string",
        "enum": ["low", "medium", "high", "no_trade"]
      },
      "intentAction": {
        "type": "string",
        "enum": [
          "evaluate_entry",
          "wait_for_confirmation",
          "hold_with_trailing_exit",
          "reduce_risk",
          "exit_or_reduce",
          "stop_breached",
          "no_trade"
        ]
      },
      "strategySpec": {
        "type": "object",
        "required": ["asset", "strategyTimeframe", "strategyType", "stopLoss", "takeProfit", "riskRules"]
      },
      "marketContext": {
        "type": "object",
        "required": ["symbol", "source", "quote", "technicals"]
      },
      "history": {
        "type": "object",
        "required": ["source", "candlesUsed", "indicatorSource", "indicators"]
      },
      "backtestSpec": {
        "type": "object",
        "required": ["strategyType", "signal", "shouldOpenPosition", "entryRule", "exitRule", "stopRule"]
      },
      "validation": {
        "type": "object",
        "required": ["backtestReady", "limitations"]
      }
    }
  },
  "dataSources": [
    {
      "name": "CoinMarketCap latest quote",
      "type": "latest_quote",
      "serverSideOnly": true,
      "endpoint": "/api/market"
    },
    {
      "name": "CoinMarketCap historical OHLCV",
      "type": "ohlcv_history",
      "serverSideOnly": true,
      "endpoint": "/api/history",
      "fallback": "estimated_candles"
    },
    {
      "name": "Local mock market context",
      "type": "demo_fallback",
      "serverSideOnly": false,
      "endpoint": "src/data/mock-market.ts"
    }
  ],
  "endpoints": {
    "market": "GET /api/market?symbol={symbol}",
    "history": "GET /api/history?symbol={symbol}&timeframe={strategyTimeframe}",
    "explain": "POST /api/explain",
    "uiExport": "Backtest-ready JSON panel in the PositionSight AI web app"
  },
  "safetyScope": {
    "financialAdvice": false,
    "tradeExecution": false,
    "walletConnection": false,
    "transactionSigning": false,
    "autonomousTrading": false,
    "shortSelling": false,
    "aiCanOverrideEngine": false,
    "notes": [
      "All strategy decisions are deterministic and generated by the rule engine.",
      "AI explanation, when enabled, may only explain the deterministic result.",
      "No API keys are exposed client-side."
    ]
  }
}
